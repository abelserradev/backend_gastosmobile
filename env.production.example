# Copiar a .env en el servidor (Coolify, VM, etc.). No commitear valores reales.

NODE_ENV=production
PORT=3088
FRONTEND_URL=https://mobilegastos.buildforge.work

# URL con TLS si el host lo exige: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

JWT_SECRET=generar_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d
COOKIE_SAME_SITE=lax
# Si front y API en dominios distintos con HTTPS: none + COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true

# Resend (dominio verificado en panel Resend)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Gastos <noreply@buildforge.work>

# Solo si usas connection pooling y Prisma te pide URL directa para migrate deploy:
# En schema.prisma: directUrl = env("DIRECT_URL")
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
