generator client {
  provider      = "prisma-client-js"
  // Alpine en Docker (musl) vs glibc en el host: sin ambos targets falla el engine en el contenedor
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum CurrencyCode {
  BS
  USD
}

enum ProfileType {
  familiar
  grupal
  comercio
}

/// Registro vía /api/auth exige email + hash; filas antiguas pueden tener null hasta limpiar datos.
model User {
  id                   String    @id @default(uuid())
  email                String?   @unique
  passwordHash         String?
  name                 String    @default("")
  failedLoginAttempts  Int       @default(0)
  lockedAt             DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  preferences          UserPreference?
  categories           Category[]
  profiles             Profile[]
  passwordResetTokens  PasswordResetToken[]
  accountUnlockCodes   AccountUnlockCode[]
  /** Muestras de corrección post-OCR (v1.3, FEAT-OCR-FB). */
  ocrCorrectionSamples OcrCorrectionSample[]
}

/// Código OTP hasheado para desbloquear cuenta tras intentos fallidos de login.
model AccountUnlockCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String   @unique
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Token de un solo uso para restablecer contraseña (hash en BD; el enlace lleva el secreto en claro).
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Moneda preferida para captura (UI); con BS el nominal va en `incomeFixedBs` y el equivalente USD se recalcula con la tasa vigente.
model UserPreference {
  id              String       @id @default(uuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCurrency CurrencyCode @default(USD)
  /// USD cuando controlás en $; si controlás en Bs., guardamos el equivalente al momento del guardado (referencia histórica).
  monthlyIncome   Decimal      @db.Decimal(14, 2)
  /// Monto nominal fijo en bolívares si `defaultCurrency` es BS.
  incomeFixedBs   Decimal?     @db.Decimal(14, 2)
  /// Tasa oficial del día en que registraste el ingreso en Bs.
  incomeRegisteredBcvRateId String?
  incomeRegisteredBcvRate     BcVOfficialRate? @relation("income_registered_rate", fields: [incomeRegisteredBcvRateId], references: [id], onDelete: SetNull)
  /// Primer día del mes (Caracas) para el cual el usuario confirmó ingreso y control mensual.
  incomeReferenceMonth DateTime? @db.Date
  /// Extra en USD arrastrado del mes anterior (no altera el ingreso base habitual).
  carryoverUsd         Decimal   @default(0) @db.Decimal(14, 2)
  /// Modo de ciclo presupuestario: 'calendar_month' o 'monthly_cutoff' (FEAT-001).
  budgetCycleMode      String    @default("calendar_month")
  /// Día del mes que CIERRA el periodo (corte). Default 1 = comportamiento calendario.
  budgetCutoffDay      Int       @default(1)
  updatedAt       DateTime     @updatedAt
}

/// Categorías de gasto por usuario (único nombre por usuario).
model Category {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  expenses  Expense[]

  @@unique([userId, name])
  @@index([userId])
}

/// Perfil tipo Netflix (familiar / grupal / comercio) bajo un usuario.
model Profile {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      ProfileType
  createdAt DateTime    @default(now())
  expenses  Expense[]
  members   ProfileMember[]

  // FEAT-002: Inventario para perfiles tipo comercio
  inventoryItems InventoryItem[]
  branches       Branch[]

  @@index([userId])
}

/// Integrantes de un perfil (modelo tipo Netflix: 1 cuenta dueña, varios nombres para auditar pagos).
model ProfileMember {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  displayName String
  createdAt   DateTime @default(now())

  paidExpenses Expense[] @relation("expense_paid_by")

  @@unique([profileId, displayName])
  @@index([profileId])
}

/// Cotización dólar oficial (DolarApi): una fila por día calendario (cache).
model BcVOfficialRate {
  id        String   @id @default(uuid())
  rateDate  DateTime @unique @db.Date
  vesPerUsd Decimal  @db.Decimal(18, 6)
  fetchedAt DateTime @default(now())

  preferencesRegisteredIncome UserPreference[] @relation("income_registered_rate")
}

/// Gasto asociado a un perfil y categoría; mes de referencia para reportes.
model Expense {
  id             String   @id @default(uuid())
  profileId      String
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title          String
  description    String   @default("")
  /// Monto en USD (única base para totales y gráficos).
  amount         Decimal  @db.Decimal(14, 2)
  isPaid         Boolean  @default(false)
  paidByDisplayName String?
  paidAt            DateTime?
  paidByMemberId   String?
  paidByMember     ProfileMember? @relation("expense_paid_by", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  referenceMonth DateTime @db.Date
  /// Día del pago (Caracas) para fijar tasa; si null, se usa hoy en Caracas.
  paymentDate    DateTime? @db.Date
  /// Bs por USD al guardar (auditoría).
  bcvRateApplied Decimal? @db.Decimal(14, 6)
  /// Día calendario de la tasa aplicada.
  bcvRateDate    DateTime? @db.Date
  /// Imagen del comprobante/factura (bytes crudos, máx ~1 MB por validación en frontend).
  receiptImage   Bytes?
  /// MIME type de receiptImage (image/jpeg, image/png, image/webp).
  receiptMime    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([profileId, referenceMonth])
  @@index([categoryId])
  @@index([paidByMemberId])
  ocrCorrectionSamples OcrCorrectionSample[]
}

/// Predicción OCR vs valores confirmados por el usuario (mobile gastos v1.3+).
model OcrCorrectionSample {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenseId String?
  expense   Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  /// IMAGE_UPLOAD_FLOW | EDIT_EXPENSE
  source String
  /// quick_confirm | detail_form (opcional, solo estadística cuando source = IMAGE_UPLOAD_FLOW)
  submissionVariant   String?
  /// payment_screenshot | physical_receipt | fiscal_or_formal_invoice | unknown
  documentKindGuess   String?

  parseSnapshot Json
  corrected     Json

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expenseId])
}

/// Tipos de movimiento de inventario (FEAT-002)
enum MovementType {
  PURCHASE      // Entrada por compra
  SALE          // Salida por venta
  ADJUSTMENT    // Corrección de stock
  INITIAL       // Stock inicial al crear producto
  RETURN        // Devolución
  TRANSFER_OUT  // Salida por transferencia (Fase B)
  TRANSFER_IN   // Entrada por transferencia (Fase B)
}

/// Producto/SKU en inventario de un perfil comercio (FEAT-002)
model InventoryItem {
  id           String   @id @default(uuid())
  profileId    String
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name         String
  sku          String?
  unit         String   @default("pieza")
  minStock     Int      @default(0)

  // Denormalizado para queries rápidas (calculado desde movimientos)
  currentStock Int      @default(0)

  movements    StockMovement[]
  branches     StockBalance[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([profileId])
  @@unique([profileId, sku])
}

/// Movimiento de stock (entrada/salida/ajuste) - inmutable (FEAT-002)
model StockMovement {
  id                String       @id @default(uuid())
  itemId            String
  item              InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type              MovementType
  quantity          Int          // positivo entrada, negativo salida
  reason            String?

  // Relación opcional con gasto (cuando la compra genera entrada)
  expenseId         String?

  // Fase B - Multi-sucursal
  branchId          String?      // sucursal donde ocurre
  branch            Branch?      @relation("movements", fields: [branchId], references: [id], onDelete: SetNull)
  targetBranchId    String?      // para transferencias: destino
  targetBranch      Branch?      @relation("target_movements", fields: [targetBranchId], references: [id], onDelete: SetNull)
  
  // Self-relation para vincular transfer_out con transfer_in (1:N para flexibilidad futura)
  relatedMovementId String?      @unique  // vincula al movimiento relacionado (transferencia par)
  relatedMovement   StockMovement? @relation("transfer_pair", fields: [relatedMovementId], references: [id])
  pairedMovements   StockMovement[] @relation("transfer_pair")

  createdAt         DateTime     @default(now())

  @@index([itemId, createdAt])
  @@index([branchId])
}

/// Sucursal de un perfil comercio (Fase B - FEAT-002)
model Branch {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  address     String?
  managerName String?  // nombre del gerente/responsable
  createdAt   DateTime @default(now())

  movements        StockMovement[] @relation("movements")
  targetMovements  StockMovement[] @relation("target_movements")
  stockBalances    StockBalance[]

  @@index([profileId])
}

/// Stock por sucursal (Fase B - FEAT-002) - denormalizado para performance
model StockBalance {
  id        String   @id @default(uuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([itemId, branchId])
  @@index([branchId])
}
