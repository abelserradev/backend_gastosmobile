# Copiar a backend/.env.docker.local y sustituir por secretos reales (no commitear .env.docker.local).
# Uso desde la raíz del repo:
#   docker compose --env-file backend/.env.docker.local up -d --build
#
# POSTGRES_* deben coincidir con usuario/clave/db de DATABASE_URL (host = nombre del servicio: postgres).

POSTGRES_USER=gastos_local
POSTGRES_PASSWORD=cambiar_clave_local
POSTGRES_DB=gastos_local
POSTGRES_PORT=55432
BACKEND_PORT=3088

NODE_ENV=development
PORT=3088
FRONTEND_URL=http://localhost:4300

DATABASE_URL=postgresql://gastos_local:cambiar_clave_local@postgres:5432/gastos_local

JWT_SECRET=cambiar_jwt_minimo_32_caracteres_local
JWT_EXPIRES_IN=7d

COOKIE_SAME_SITE=lax

# Opcional
# RESEND_API_KEY=
# EMAIL_FROM=
# FIREBASE_SERVICE_ACCOUNT_JSON=
