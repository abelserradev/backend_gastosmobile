# Copiar a .env según entorno (no commitear secretos reales).

NODE_ENV=development
PORT=3088

# Orígenes del front (Angular); varios separados por coma (puerto distinto de 4200/4201 si convive con otros proyectos)
FRONTEND_URL=http://localhost:4300

# PostgreSQL — en Docker usa backend/.env.docker.local (ver backend/env.docker.local.example).
# Nest en el host: DATABASE_URL con localhost y el puerto publicado (POSTGRES_PORT del .env.docker.local o el que uses).
# DATABASE_URL=postgresql://USUARIO:PASSWORD@localhost:55432/NOMBRE_DB
DATABASE_URL=postgresql://mobilegastos:mobilegastos_dev@localhost:55432/mobilegastos

# JWT: mín. 16 chars en dev (validación al arrancar), mín. 32 en producción.
JWT_SECRET=cambiar_en_produccion_minimo_32_caracteres_seguros
JWT_EXPIRES_IN=7d

# Cookie HttpOnly del JWT: lax (mismo sitio) | none (cross-subdominio, exige HTTPS + COOKIE_SECURE)
COOKIE_SAME_SITE=lax
# Forzar Secure en dev si probás con HTTPS local
# COOKIE_SECURE=true

# Producción con pooler (Neon, Supavisor, PgBouncer): añadir a la URL, p. ej.
# ?pgbouncer=true&connect_timeout=15
# Si el proveedor exige URL “directa” para migraciones, duplicar en schema.prisma
# con directUrl y variable DIRECT_URL (ver documentación de Prisma).

# DolarApi Venezuela (opcional; default https://ve.dolarapi.com)
# DOLARAPI_BASE_URL=https://ve.dolarapi.com

# Firebase Admin: JSON minificado de la cuenta de servicio (verificación de ID token Google).
# Sin esto, POST /api/auth/firebase responde 503.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Resend (correo transaccional; la key solo en servidor / .env local gitignored)
# RECUPERACIÓN DE CONTRASEÑA: sin RESEND_API_KEY el backend igual responde OK pero registra el enlace en logs (dev).
# FRONTEND_URL debe ser el origen del SPA (ej. …/reset-password?token=… en el correo).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Gastos <noreply@buildforge.work>

# OCR híbrido: Tesseract.js + glm-ocr vía Ollama (opcional pero recomendado).
# Desarrollo en host con Ollama local: OLLAMA_URL=http://localhost:11434
# Backend en Docker (compose local): OLLAMA_URL=http://ollama:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=glm-ocr
OLLAMA_OCR_ENABLED=true
# CPU sin GPU: usar ≥300000 (5 min). Con GPU suele bastar 120000–180000.
OLLAMA_OCR_TIMEOUT_MS=300000
OLLAMA_OCR_WARMUP=true
# Variante más ligera en CPU: glm-ocr:q8_0 (~1.6 GB)
# OLLAMA_MODEL=glm-ocr:q8_0
